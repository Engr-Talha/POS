{
  "name": "pos-insha-desktop",
  "productName": "Insha POS",
  "version": "0.18.0",
  "description": "Offline Point of Sale",
  "main": "./out/main/index.js",
  "author": "Insha",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "app": "open 'release/mac-arm64/Insha POS.app'",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "make:icon": "electron scripts/make-icon.cjs",
    "make:keypair": "tsx --tsconfig tsconfig.node.json tools/make-keypair.ts",
    "keygen": "tsx --tsconfig tsconfig.node.json tools/keygen.ts",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "rm -rf node_modules/better-sqlite3/build && electron-builder install-app-deps",
    "test": "npm run rebuild:node && vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && electron-vite build",
    "build:mac": "npm run rebuild:electron && npm run build && electron-builder --mac --publish never",
    "build:win": "npm run rebuild:electron && npm run build && electron-builder --win --publish never",
    "postinstall": "electron-builder install-app-deps",
    "receipt:preview": "node scripts/build-receipt-preview.mjs && electron scripts/render-receipt.cjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.19",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
